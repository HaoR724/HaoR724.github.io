<div class="col mb-4">
  <a href="{% if project.redirect %}{{ project.redirect }}{% else %}{{ project.url | relative_url }}{% endif %}">
    <div class="card h-100 hoverable">
      <div class="row no-gutters">
        {% if project.img %}
          <div class="col-md-6">
            {% include figure.liquid loading="eager" path=project.img sizes="(min-width: 768px) 156px, 50vw" alt="项目缩略图" class="card-img" %}
          </div>
        {% endif %}
        <div class="{% if project.img %}col-md-6{% else %}col-md-12{% endif %}">
          <div class="card-body">
            {% if project.role %}
              <p class="project-listing__meta">{{ project.role }}</p>
            {% elsif project.period %}
              <p class="project-listing__meta">{{ project.period }}</p>
            {% endif %}
            <h3 class="card-title">
              <span class="project-card__icon"><i class="fa-solid fa-stars"></i></span>
              <span>{{ project.title }}</span>
            </h3>
            <p class="card-text">{{ project.description }}</p>
            {% if project.keywords %}
              <div class="project-listing__tags">
                {% for keyword in project.keywords limit: 3 %}
                  <span>{{ keyword }}</span>
                {% endfor %}
              </div>
            {% endif %}
            <div class="project-listing__actions">
              <span class="project-listing__cta"><i class="fa-solid fa-arrow-right"></i><span>查看项目</span></span>
              {% if project.github %}
                <div class="github-icon">
                  <div class="icon" data-toggle="tooltip" title="代码仓库">
                    <a href="{{ project.github }}"><i class="fa-brands fa-github gh-icon"></i></a>
                  </div>
                  {% if project.github_stars %}
                    <span class="stars" data-toggle="tooltip" title="GitHub 星标">
                      <i class="fa-solid fa-star"></i>
                      <span id="{{ project.github_stars }}-stars"></span>
                    </span>
                  {% endif %}
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </a>
</div>
