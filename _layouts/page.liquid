---
layout: default
---
{% if page._styles %}
  <!-- Page/Post style -->
  <style type="text/css">
    {{ page._styles }}
  </style>
{% endif %}

<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {% if page.url contains '/projects/' %}
        <span class="post-title__icon"><i class="fa-solid fa-sparkles"></i></span>
      {% endif %}
      <span>{{ page.title }}</span>
    </h1>
    <p class="post-description">{{ page.description }}</p>
  </header>

  <article>
    {% if page.url contains '/projects/' %}
      <div class="detail-shell detail-shell--project">
        <aside class="detail-timeline" aria-label="项目章节导航">
          <div class="detail-timeline__sticky">
            <p class="detail-timeline__eyebrow"><i class="fa-solid fa-route"></i><span>项目脉络</span></p>
            <p class="detail-timeline__current">{{ page.title }}</p>
            <div class="detail-timeline__rail">
              <span class="detail-timeline__line"></span>
              <ol class="detail-timeline__nav"></ol>
            </div>
          </div>
        </aside>
        <div class="detail-shell__content detail-shell__content--project">
          <section class="project-overview">
            <div class="project-overview__intro">
              <p class="project-overview__eyebrow"><i class="fa-solid fa-satellite-dish"></i><span>项目摘要</span></p>
              {% if page.project_summary %}
                <p class="project-overview__summary">{{ page.project_summary }}</p>
              {% elsif page.description %}
                <p class="project-overview__summary">{{ page.description }}</p>
              {% endif %}
            </div>
            <div class="project-overview__grid">
              {% if page.role %}
                <div class="project-overview__card">
                  <span class="project-overview__label">角色</span>
                  <strong>{{ page.role }}</strong>
                </div>
              {% endif %}
              {% if page.period %}
                <div class="project-overview__card">
                  <span class="project-overview__label">时间</span>
                  <strong>{{ page.period }}</strong>
                </div>
              {% endif %}
              {% if page.category %}
                <div class="project-overview__card">
                  <span class="project-overview__label">类型</span>
                  <strong>{{ page.category }}</strong>
                </div>
              {% endif %}
            </div>
            {% if page.keywords %}
              <div class="project-overview__tags" aria-label="项目关键词">
                {% for keyword in page.keywords %}
                  <span>{{ keyword }}</span>
                {% endfor %}
              </div>
            {% endif %}
            {% if page.project_links %}
              <div class="project-links">
                {% for link in page.project_links %}
                  <a
                    class="project-link"
                    href="{% if link.url contains '://' %}{{ link.url }}{% else %}{{ link.url | relative_url }}{% endif %}"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {% if link.icon %}<i class="{{ link.icon }}"></i>{% endif %}<span>{{ link.label }}</span>
                  </a>
                {% endfor %}
              </div>
            {% endif %}
          </section>
          {{ content }}
        </div>
      </div>
    {% else %}
      {{ content }}
    {% endif %}
  </article>

  {% if page.related_publications %}
    <h2>References</h2>
    <div class="publications">
      {% bibliography --cited_in_order %}
    </div>
  {% endif %}

  {% if site.giscus and page.giscus_comments %}
    {% include giscus.liquid %}
  {% endif %}
</div>
